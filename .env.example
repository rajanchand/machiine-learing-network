# ==============================================================================
# Anomaly Guard - Environment Configuration Template
# ==============================================================================
# Copy this file to .env at the root directory or inside the backend directory:
#   cp .env.example .env
# Adjust the values below to match your environment.

# ------------------------------------------------------------------------------
# 1. Database Configuration
# ------------------------------------------------------------------------------
# By default, for local development, you can use SQLite.
# For production/Docker setups, use PostgreSQL.

# Local Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///../anomaly_detection.db
DATABASE_URL_SYNC=sqlite:///../anomaly_detection.db

# Production / Docker Deployment (PostgreSQL) - Uncomment to use
# POSTGRES_DB=anomaly_detection
# POSTGRES_USER=anomaly
# POSTGRES_PASSWORD=changeme_in_production
# DATABASE_URL=postgresql+asyncpg://anomaly:changeme_in_production@db:5432/anomaly_detection
# DATABASE_URL_SYNC=postgresql+psycopg2://anomaly:changeme_in_production@db:5432/anomaly_detection

# ------------------------------------------------------------------------------
# 2. FastAPI API Server Configuration
# ------------------------------------------------------------------------------
# API_HOST: Host IP for the FastAPI server to bind to (e.g., 127.0.0.1 for local, 0.0.0.0 for Docker)
API_HOST=127.0.0.1
# API_PORT: Port number for the FastAPI backend server
API_PORT=8000
# LOG_LEVEL: Severity of logged messages (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# CORS_ORIGINS: JSON list of authorized frontend origins for CORS headers
CORS_ORIGINS=["http://localhost:5173", "http://localhost:5174"]

# ------------------------------------------------------------------------------
# 3. Model Registry & Data Directory Paths
# ------------------------------------------------------------------------------
# MODEL_REGISTRY_PATH: Path to the directory where ML model artifacts are stored
MODEL_REGISTRY_PATH=../models
# DATA_DIR: Directory where processed baseline data (scaler.joblib, train.parquet) resides
DATA_DIR=../data

# ------------------------------------------------------------------------------
# 4. Traffic Simulator Configuration
# ------------------------------------------------------------------------------
# SIMULATOR_API_URL: The base API address the simulator sends replayed traffic flows to
SIMULATOR_API_URL=http://localhost:8000
# SIMULATOR_RATE_PER_SEC: Number of network flow replay events to post per second
SIMULATOR_RATE_PER_SEC=10
# SIMULATOR_DATA_PATH: Filepath to the CSV replay file (e.g., NSL-KDD / CIC-IDS2017)
SIMULATOR_DATA_PATH=../data/fixtures/cicids2017_sample.csv

# ------------------------------------------------------------------------------
# 5. Frontend Dashboard Configuration
# ------------------------------------------------------------------------------
# VITE_API_URL: API base URL that the Vite frontend dev server targets for client polling
VITE_API_URL=http://localhost:8000
